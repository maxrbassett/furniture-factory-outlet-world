---
import * as site from '@data/site';
const { active } = Astro.props as { active?: string };
---
<a href={site.promo.href} class="group block bg-brass-500 text-walnut-900 transition-colors hover:bg-brass-400">
  <div class="mx-auto max-w-6xl px-4 py-2 text-center text-sm sm:px-6">
    <span class="font-700">{site.promo.text}</span>
    <span class="ml-2 font-600 underline decoration-walnut-900/40 underline-offset-2 group-hover:decoration-walnut-900">{site.promo.cta} &rarr;</span>
  </div>
</a>

<header class="sticky top-0 z-40 border-b border-line bg-cream/90 backdrop-blur">
  <!-- Main bar: logo · search · actions -->
  <div class="mx-auto flex max-w-6xl items-center gap-4 px-4 py-3 sm:px-6">
    <a href="/" class="flex shrink-0 items-center gap-2.5">
      <img src="/favicon.png" alt="" width="46" height="46" class="-my-1" />
      <span class="font-display text-base font-700 leading-tight text-walnut-700 sm:text-lg">
        Furniture Factory<br class="hidden sm:block" /> Outlet World
      </span>
    </a>

    <!-- Prominent search (md+): submits to the catalog, filters there -->
    <form action="/catalog" method="get" role="search" class="hidden min-w-0 flex-1 md:flex md:max-w-md lg:max-w-lg">
      <label for="nav-search" class="sr-only">Search furniture</label>
      <div class="relative w-full">
        <svg class="pointer-events-none absolute left-3.5 top-1/2 h-4 w-4 -translate-y-1/2 text-ink-soft" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <circle cx="11" cy="11" r="7" /><path d="m21 21-4.3-4.3" stroke-linecap="round" />
        </svg>
        <input
          id="nav-search"
          type="search"
          name="q"
          placeholder="Search sofas, beds, dining…"
          class="w-full rounded-full border border-line bg-paper py-2.5 pl-10 pr-4 text-sm text-walnut-700 placeholder:text-ink-soft/60 focus:border-brass-500 focus:outline-none focus:ring-2 focus:ring-brass-500/30"
        />
      </div>
    </form>

    <div class="flex shrink-0 items-center gap-2">
      <a href={`tel:${site.phoneTel}`} class="hidden rounded-full bg-walnut-600 px-4 py-2 text-sm font-600 text-cream transition-colors hover:bg-walnut-700 lg:inline-flex">
        Call {site.phone}
      </a>
      <a href="/catalog" class="rounded-full bg-brass-500 px-4 py-2 text-sm font-700 text-walnut-900 transition-colors hover:bg-brass-400">
        Shop
      </a>
      <button
        type="button"
        id="nav-toggle"
        class="inline-flex h-10 w-10 items-center justify-center rounded-lg border border-line text-walnut-700 lg:hidden"
        aria-expanded="false"
        aria-controls="nav-mobile"
      >
        <span class="sr-only">Toggle menu</span>
        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M3 6h18M3 12h18M3 18h18" stroke-linecap="round"/></svg>
      </button>
    </div>
  </div>

  <!-- Secondary category bar (desktop) -->
  <nav class="hidden border-t border-line lg:block" aria-label="Primary">
    <ul class="mx-auto flex max-w-6xl items-center gap-7 px-4 py-2.5 sm:px-6">
      {site.nav.map((item) => (
        <li>
          <a
            href={item.href}
            class:list={[
              'text-sm font-600 text-ink-soft transition-colors hover:text-walnut-600',
              active === item.href && 'text-walnut-700 underline underline-offset-4',
            ]}
          >{item.label}</a>
        </li>
      ))}
    </ul>
  </nav>

  <!-- Mobile menu -->
  <div id="nav-mobile" class="hidden border-t border-line bg-cream px-4 pb-4 pt-3 lg:hidden">
    <form action="/catalog" method="get" role="search" class="mb-3">
      <label for="nav-search-mobile" class="sr-only">Search furniture</label>
      <div class="relative w-full">
        <svg class="pointer-events-none absolute left-3.5 top-1/2 h-4 w-4 -translate-y-1/2 text-ink-soft" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <circle cx="11" cy="11" r="7" /><path d="m21 21-4.3-4.3" stroke-linecap="round" />
        </svg>
        <input id="nav-search-mobile" type="search" name="q" placeholder="Search sofas, beds, dining…" class="w-full rounded-full border border-line bg-paper py-2.5 pl-10 pr-4 text-sm text-walnut-700 placeholder:text-ink-soft/60 focus:border-brass-500 focus:outline-none focus:ring-2 focus:ring-brass-500/30" />
      </div>
    </form>
    <ul class="flex flex-col gap-1">
      {site.nav.map((item) => (
        <li><a href={item.href} class="block rounded-lg px-3 py-2.5 text-sm font-600 text-ink-soft hover:bg-cream-deep">{item.label}</a></li>
      ))}
      <li><a href={`tel:${site.phoneTel}`} class="block rounded-lg px-3 py-2.5 text-sm font-600 text-walnut-700 hover:bg-cream-deep">Call {site.phone}</a></li>
    </ul>
  </div>
</header>

<script>
  const toggle = document.getElementById('nav-toggle');
  const menu = document.getElementById('nav-mobile');
  toggle?.addEventListener('click', () => {
    const open = toggle.getAttribute('aria-expanded') === 'true';
    toggle.setAttribute('aria-expanded', String(!open));
    menu?.classList.toggle('hidden', open);
  });
</script>
