---
import * as site from '@data/site';
---
<section class="bg-walnut-600 py-14 text-cream sm:py-16">
  <div class="mx-auto max-w-6xl px-4 sm:px-6">
    <p class="font-display text-sm font-600 uppercase tracking-[0.18em] text-brass-300">In their words</p>
    <h2 class="mt-2 font-display text-3xl font-700 sm:text-4xl">What customers say</h2>
    <p class="mt-2 max-w-xl text-sm text-cream/70">Placeholder quotes shown for layout only — real, permissioned reviews go here before launch.</p>
    <div class="mt-9 grid gap-5 md:grid-cols-3">
      {site.reviews.map((r) => (
        <figure class="rounded-2xl border border-cream/15 bg-walnut-700/50 p-6">
          <div class="text-brass-300" aria-hidden="true">&#9733;&#9733;&#9733;&#9733;&#9733;</div>
          <blockquote class="mt-3 text-sm leading-relaxed text-cream/90">&ldquo;{r.quote}&rdquo;</blockquote>
          <figcaption class="mt-4 text-xs font-600 uppercase tracking-wide text-cream/60">— {r.attribution} <span class="text-brass-300">(placeholder)</span></figcaption>
        </figure>
      ))}
    </div>
  </div>
</section>
