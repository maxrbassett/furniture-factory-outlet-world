---
import * as site from '@data/site';
---
<footer class="border-t border-line bg-walnut-700 text-cream">
  <div class="mx-auto grid max-w-6xl gap-10 px-4 py-12 sm:px-6 md:grid-cols-3">
    <div>
      <div class="flex items-center gap-2.5">
        <img src="/favicon.png" alt="" width="50" height="50" />
        <span class="font-display text-lg font-700">{site.name}</span>
      </div>
      <p class="mt-3 max-w-xs text-sm text-cream/80">{site.establishedLine}.</p>
      <p class="mt-3 text-xs text-cream/60">Preview site — content marked POC is placeholder pending owner confirmation.</p>
    </div>

    <div>
      <h2 class="font-display text-sm font-700 uppercase tracking-wide text-brass-300">Visit</h2>
      <address class="mt-3 not-italic text-sm leading-relaxed text-cream/85">
        {site.addressOneLine}<br />
        <a href={`tel:${site.phoneTel}`} class="underline-offset-2 hover:underline">{site.phone}</a>
      </address>
      <a href={site.directionsUrl} class="mt-3 inline-block text-sm font-600 text-brass-300 underline-offset-2 hover:underline">Get directions</a>
    </div>

    <div>
      <h2 class="font-display text-sm font-700 uppercase tracking-wide text-brass-300">Hours</h2>
      <dl class="mt-3 space-y-1 text-sm text-cream/85">
        {site.hoursOrder.map((k) => (
          <div class="flex justify-between gap-4">
            <dt>{site.hours[k].label}</dt>
            <dd>{site.hours[k].display}</dd>
          </div>
        ))}
      </dl>
    </div>
  </div>

  <div class="border-t border-cream/15 px-4 py-5 text-center text-xs text-cream/60 sm:px-6">
    &copy; {new Date().getFullYear()} {site.name}. All hours, prices and details shown are placeholders pending confirmation.
    <span aria-hidden="true" class="mx-2 text-cream/30">·</span>
    <a href="/quick-add" class="font-600 text-brass-300 underline-offset-2 hover:underline">Owner: add new arrivals</a>
  </div>
</footer>
