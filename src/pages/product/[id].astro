---
import Layout from '@layouts/Layout.astro';
import Nav from '@components/Nav.astro';
import SiteFooter from '@components/SiteFooter.astro';
import DemoNotice from '@components/DemoNotice.astro';
import ProductPlaceholder from '@components/ProductPlaceholder.astro';
import ProductCard from '@components/ProductCard.astro';
import { inventory, relatedTo, formatPrice } from '@data/inventory';
import type { Product } from '@data/inventory';

export function getStaticPaths() {
  return inventory.map((product) => ({
    params: { id: product.id },
    props: { product },
  }));
}

const { product } = Astro.props as { product: Product };
const related = relatedTo(product);

const specs: [string, string][] = [
  ['Dimensions (W×D×H, in.)', product.dimensions],
  ['Material', product.material],
  ['Color', product.color],
  ['Style', product.style],
  ['Room', product.room],
  ['Category', product.category],
];

const title = `${product.name} | Furniture Factory Outlet World`;
const description = `${product.name} — ${product.blurb} ${formatPrice(product.price)} (placeholder demo pricing).`;
---
<Layout title={title} description={description}>
  <a href="#main" class="skip-link">Skip to content</a>
  <Nav active="/catalog" />
  <main id="main" class="bg-cream">
    <div class="mx-auto max-w-6xl px-4 py-8 sm:px-6">
      <nav aria-label="Breadcrumb" class="text-sm text-ink-soft">
        <a href="/" class="hover:underline">Home</a> <span aria-hidden="true">/</span>
        <a href="/catalog" class="hover:underline">Catalog</a> <span aria-hidden="true">/</span>
        <a href={`/catalog?category=${encodeURIComponent(product.category)}`} class="hover:underline">{product.category}</a>
        <span aria-hidden="true">/</span> <span class="font-600 text-walnut-700">{product.name}</span>
      </nav>

      <div class="mt-6 grid gap-10 lg:grid-cols-2">
        <!-- Gallery -->
        <div>
          <ProductPlaceholder name={product.name} category={product.category} color={product.color} ratio="4 / 3" class="border border-line" />
          <div class="mt-3 grid grid-cols-4 gap-3" aria-label="Thumbnail gallery (placeholder)">
            {[0, 1, 2, 3].map(() => (
              <ProductPlaceholder name={product.name} category={product.category} color={product.color} ratio="1 / 1" showLabel={false} class="border border-line opacity-90" />
            ))}
          </div>
          <p class="mt-2 text-xs text-ink-soft/60">Gallery images are placeholders — replace with real product photos.</p>
        </div>

        <!-- Info -->
        <div>
          <p class="font-display text-sm font-600 uppercase tracking-[0.18em] text-brass-600">{product.category} · {product.style}</p>
          <h1 class="mt-2 font-display text-3xl font-700 text-walnut-700 sm:text-4xl">{product.name}</h1>

          <div class="mt-4 flex flex-wrap items-center gap-3">
            <span class="font-display text-3xl font-700 text-brass-700">{formatPrice(product.price)}</span>
            <span class:list={[
              'inline-flex items-center gap-1.5 rounded-full px-3 py-1 text-xs font-600',
              product.inStock ? 'bg-sage-500/15 text-sage-700' : 'bg-walnut-100 text-walnut-600',
            ]}>
              <span class:list={['h-1.5 w-1.5 rounded-full', product.inStock ? 'bg-sage-600' : 'bg-walnut-400']}></span>
              {product.inStock ? 'In stock' : 'Made to order'}
            </span>
          </div>
          <p class="mt-1 text-xs text-ink-soft/60">Price is placeholder demo data — confirm before launch.</p>

          <p class="mt-5 leading-relaxed text-ink-soft">{product.blurb}</p>

          <div class="mt-6 flex flex-wrap gap-3">
            <button
              type="button"
              class="rounded-full bg-brass-500 px-6 py-3 font-700 text-walnut-900 shadow-lg shadow-brass-500/30 hover:bg-brass-400"
              data-demo={`Reserving “${product.name}” isn’t connected in this preview. In the live store this would hold the piece for you. For now, please call to reserve.`}
            >
              Reserve this piece
            </button>
            <button
              type="button"
              class="rounded-full border border-walnut-600 px-6 py-3 font-600 text-walnut-700 hover:bg-walnut-600 hover:text-cream"
              data-demo={`Live availability for “${product.name}” isn’t wired up in this preview. In the live store this would check current stock. For now, please call to check.`}
            >
              Check availability
            </button>
          </div>

          <!-- Specs -->
          <div class="mt-8 overflow-hidden rounded-2xl border border-line bg-paper">
            <h2 class="border-b border-line px-5 py-3 font-display text-sm font-700 uppercase tracking-wide text-walnut-700">Specifications</h2>
            <dl class="divide-y divide-line">
              {specs.map(([k, v]) => (
                <div class="flex justify-between gap-4 px-5 py-3 text-sm">
                  <dt class="text-ink-soft">{k}</dt>
                  <dd class="text-right font-600 text-walnut-700">{v}</dd>
                </div>
              ))}
            </dl>
            <p class="px-5 py-3 text-xs text-ink-soft/60">Specs are placeholder demo data — confirm exact dimensions and materials.</p>
          </div>
        </div>
      </div>

      <!-- Related -->
      {related.length > 0 && (
        <section class="mt-16" aria-label="Related pieces">
          <h2 class="font-display text-2xl font-700 text-walnut-700">You might also like</h2>
          <div class="mt-6 grid gap-5 sm:grid-cols-2 xl:grid-cols-4">
            {related.map((r) => <ProductCard product={r} />)}
          </div>
        </section>
      )}

      <div class="mt-12">
        <a href="/catalog" class="inline-flex items-center gap-2 text-sm font-600 text-walnut-600 hover:underline">&larr; Back to catalog</a>
      </div>
    </div>
  </main>
  <SiteFooter />
  <DemoNotice />
</Layout>
