---
import Layout from '@layouts/Layout.astro';
import Nav from '@components/Nav.astro';
import SiteFooter from '@components/SiteFooter.astro';
import DemoNotice from '@components/DemoNotice.astro';
import CatalogFilters from '@components/CatalogFilters.astro';
import ProductCard from '@components/ProductCard.astro';
import { inventory } from '@data/inventory';

const title = 'Catalog | Furniture Factory Outlet World';
const description = 'Browse the full Furniture Factory Outlet World catalog — search and filter sofas, sectionals, beds, dining, recliners and more by room, price, style and color. (Placeholder inventory.)';
---
<Layout title={title} description={description}>
  <a href="#main" class="skip-link">Skip to content</a>
  <Nav active="/catalog" />
  <main id="main" class="bg-cream">
    <!-- Header -->
    <div class="border-b border-line bg-cream-deep">
      <div class="mx-auto max-w-6xl px-4 py-10 sm:px-6">
        <nav aria-label="Breadcrumb" class="text-sm text-ink-soft">
          <a href="/" class="hover:underline">Home</a> <span aria-hidden="true">/</span> <span class="font-600 text-walnut-700">Catalog</span>
        </nav>
        <h1 class="mt-3 font-display text-4xl font-700 text-walnut-700 sm:text-5xl">The Catalog</h1>
        <p class="mt-3 max-w-2xl text-ink-soft">
          Every piece here is placeholder demo inventory. Search, filter and sort to see how the live store will work — your filtered view stays in the URL so you can share it or use the back button.
        </p>
      </div>
    </div>

    <div class="mx-auto max-w-6xl gap-8 px-4 py-8 sm:px-6 lg:flex lg:items-start">
      <!-- Filters: mobile disclosure + desktop sidebar -->
      <aside class="lg:w-72 lg:shrink-0">
        <details class="rounded-2xl border border-line bg-paper lg:hidden" id="filters-disclosure">
          <summary class="cursor-pointer list-none px-5 py-3.5 font-display font-700 text-walnut-700">
            <span class="flex items-center justify-between">Filters &amp; search <span aria-hidden="true">▾</span></span>
          </summary>
          <div class="border-t border-line px-5 py-5" id="filters-slot-mobile"></div>
        </details>

        <div class="sticky top-20 hidden rounded-2xl border border-line bg-paper p-5 lg:block" id="filters-slot-desktop">
          <CatalogFilters />
        </div>
      </aside>

      <!-- Results -->
      <section class="mt-6 min-w-0 flex-1 lg:mt-0" aria-label="Catalog results">
        <div class="flex flex-wrap items-center justify-between gap-3 rounded-2xl border border-line bg-paper px-4 py-3">
          <p class="text-sm text-ink-soft" aria-live="polite">
            <span id="results-count" class="font-700 text-walnut-700">{inventory.length}</span> of <span id="results-total">{inventory.length}</span> pieces
          </p>
          <label class="flex items-center gap-2 text-sm text-ink-soft">
            <span class="font-600">Sort</span>
            <select id="sort-select" class="rounded-xl border border-line bg-cream px-3 py-2 text-sm font-600 text-walnut-700">
              <option value="featured">Featured</option>
              <option value="price-asc">Price: low to high</option>
              <option value="price-desc">Price: high to low</option>
              <option value="name">Name: A–Z</option>
            </select>
          </label>
        </div>

        <!-- Active filter chips -->
        <div id="active-chips" class="mt-4 flex flex-wrap gap-2"></div>

        <!-- Grid -->
        <div id="catalog-grid" class="mt-4 grid gap-5 sm:grid-cols-2 xl:grid-cols-3">
          {inventory.map((p) => (
            <div
              class="catalog-item"
              data-id={p.id}
              data-name={p.name}
              data-category={p.category}
              data-room={p.room}
              data-style={p.style}
              data-color={p.color}
              data-price={p.price}
              data-instock={String(p.inStock)}
              data-featured={String(p.featured)}
              data-search={`${p.name} ${p.category} ${p.room} ${p.style} ${p.color} ${p.material} ${p.blurb}`.toLowerCase()}
            >
              <ProductCard product={p} />
            </div>
          ))}
        </div>

        <!-- Empty state -->
        <div id="empty-state" class="hidden rounded-2xl border border-dashed border-line bg-paper px-6 py-16 text-center">
          <h2 class="font-display text-2xl font-700 text-walnut-700">No pieces match those filters</h2>
          <p class="mx-auto mt-2 max-w-sm text-sm text-ink-soft">Try widening your price range or clearing a filter — there are plenty more pieces to see.</p>
          <button type="button" id="empty-clear" class="mt-5 rounded-full bg-brass-500 px-5 py-2.5 text-sm font-700 text-walnut-900 hover:bg-brass-400">Clear all filters</button>
        </div>
      </section>
    </div>
  </main>
  <SiteFooter />
  <DemoNotice />
</Layout>

<script>
  import { getPublished, buildCard } from '../scripts/newArrivals';

  // --- Inject client-side "New Arrivals" (published via the Quick-Add tool) ---
  // They become regular .catalog-item nodes so search / filter / sort just work.
  const catalogGrid = document.getElementById('catalog-grid');
  if (catalogGrid) {
    const published = getPublished(); // newest first
    for (let i = published.length - 1; i >= 0; i--) {
      catalogGrid.prepend(buildCard(published[i]));
    }
  }

  // --- Move the single filter form to the active layout (mobile vs desktop) ---
  const desktopSlot = document.getElementById('filters-slot-desktop');
  const mobileSlot = document.getElementById('filters-slot-mobile');
  const mq = window.matchMedia('(min-width: 1024px)');

  function placeFilters() {
    const form = document.getElementById('catalog-filters');
    if (!form) return;
    if (mq.matches) desktopSlot?.appendChild(form);
    else mobileSlot?.appendChild(form);
  }
  placeFilters();
  mq.addEventListener('change', placeFilters);

  // --- Elements ---
  const grid = document.getElementById('catalog-grid')!;
  const items = Array.from(document.querySelectorAll<HTMLElement>('.catalog-item'));
  document.getElementById('results-total')!.textContent = String(items.length);
  const countEl = document.getElementById('results-count')!;
  const emptyEl = document.getElementById('empty-state')!;
  const chipsEl = document.getElementById('active-chips')!;
  const sortSelect = document.getElementById('sort-select') as HTMLSelectElement;

  const checkboxNames = ['room', 'category', 'style', 'color'] as const;
  type MultiKey = typeof checkboxNames[number];

  function form() {
    return document.getElementById('catalog-filters') as HTMLFormElement | null;
  }
  function input(name: string) {
    return form()?.querySelector<HTMLInputElement>(`[name="${name}"]`) ?? null;
  }
  function checkedValues(name: MultiKey): string[] {
    const f = form();
    if (!f) return [];
    return Array.from(f.querySelectorAll<HTMLInputElement>(`input[name="${name}"]:checked`)).map((i) => i.value);
  }

  // --- Read / write URL state ---
  function readURLIntoForm() {
    const params = new URLSearchParams(location.search);
    const f = form();
    if (!f) return;
    const q = input('q'); if (q) q.value = params.get('q') ?? '';
    const min = input('min'); if (min) min.value = params.get('min') ?? '';
    const max = input('max'); if (max) max.value = params.get('max') ?? '';
    const instock = input('instock') as HTMLInputElement | null;
    if (instock) instock.checked = params.get('instock') === '1';
    for (const name of checkboxNames) {
      const wanted = new Set(params.getAll(name).flatMap((v) => v.split(',')));
      f.querySelectorAll<HTMLInputElement>(`input[name="${name}"]`).forEach((cb) => {
        cb.checked = wanted.has(cb.value);
      });
    }
    const sort = params.get('sort');
    if (sort) sortSelect.value = sort;
  }

  function writeURL() {
    const params = new URLSearchParams();
    const q = input('q')?.value.trim();
    if (q) params.set('q', q);
    for (const name of checkboxNames) {
      const vals = checkedValues(name);
      if (vals.length) params.set(name, vals.join(','));
    }
    const min = input('min')?.value.trim();
    const max = input('max')?.value.trim();
    if (min) params.set('min', min);
    if (max) params.set('max', max);
    if ((input('instock') as HTMLInputElement | null)?.checked) params.set('instock', '1');
    if (sortSelect.value !== 'featured') params.set('sort', sortSelect.value);
    const qs = params.toString();
    history.replaceState(null, '', qs ? `?${qs}` : location.pathname);
  }

  // --- Chips ---
  function renderChips() {
    chipsEl.innerHTML = '';
    const add = (label: string, onRemove: () => void) => {
      const btn = document.createElement('button');
      btn.type = 'button';
      btn.className =
        'inline-flex items-center gap-1.5 rounded-full bg-walnut-100 px-3 py-1.5 text-xs font-600 text-walnut-700 hover:bg-walnut-200';
      btn.innerHTML = `${label} <span aria-hidden="true">×</span>`;
      btn.setAttribute('aria-label', `Remove filter ${label}`);
      btn.addEventListener('click', () => { onRemove(); apply(); });
      chipsEl.appendChild(btn);
    };
    for (const name of checkboxNames) {
      for (const val of checkedValues(name)) {
        add(val, () => {
          const el = form()?.querySelector<HTMLInputElement>(`input[name="${name}"][value="${CSS.escape(val)}"]`);
          if (el) el.checked = false;
        });
      }
    }
    if ((input('instock') as HTMLInputElement | null)?.checked) {
      add('In stock only', () => { const el = input('instock') as HTMLInputElement; el.checked = false; });
    }
    const min = input('min')?.value.trim();
    const max = input('max')?.value.trim();
    if (min || max) {
      add(`$${min || '0'}–$${max || '∞'}`, () => {
        const mn = input('min'); if (mn) mn.value = '';
        const mx = input('max'); if (mx) mx.value = '';
      });
    }
  }

  // --- Sorting ---
  function sortItems() {
    const mode = sortSelect.value;
    const sorted = [...items].sort((a, b) => {
      const pa = Number(a.dataset.price), pb = Number(b.dataset.price);
      switch (mode) {
        case 'price-asc': return pa - pb;
        case 'price-desc': return pb - pa;
        case 'name': return (a.dataset.name || '').localeCompare(b.dataset.name || '');
        case 'featured':
        default:
          return (Number(b.dataset.featured === 'true') - Number(a.dataset.featured === 'true'))
            || (a.dataset.name || '').localeCompare(b.dataset.name || '');
      }
    });
    sorted.forEach((el) => grid.appendChild(el));
  }

  // --- Apply filters ---
  function apply() {
    const q = (input('q')?.value || '').trim().toLowerCase();
    const rooms = checkedValues('room');
    const cats = checkedValues('category');
    const stylesSel = checkedValues('style');
    const colorsSel = checkedValues('color');
    const min = parseFloat(input('min')?.value || '');
    const max = parseFloat(input('max')?.value || '');
    const inStockOnly = (input('instock') as HTMLInputElement | null)?.checked;

    let visible = 0;
    for (const el of items) {
      const d = el.dataset;
      let show = true;
      if (q && !(d.search || '').includes(q)) show = false;
      if (show && rooms.length && !rooms.includes(d.room || '')) show = false;
      if (show && cats.length && !cats.includes(d.category || '')) show = false;
      if (show && stylesSel.length && !stylesSel.includes(d.style || '')) show = false;
      if (show && colorsSel.length && !colorsSel.includes(d.color || '')) show = false;
      if (show && !Number.isNaN(min) && Number(d.price) < min) show = false;
      if (show && !Number.isNaN(max) && Number(d.price) > max) show = false;
      if (show && inStockOnly && d.instock !== 'true') show = false;
      el.classList.toggle('hidden', !show);
      if (show) visible++;
    }

    countEl.textContent = String(visible);
    emptyEl.classList.toggle('hidden', visible !== 0);
    grid.classList.toggle('hidden', visible === 0);
    sortItems();
    renderChips();
    writeURL();
  }

  function clearAll() {
    const f = form();
    f?.reset();
    f?.querySelectorAll<HTMLInputElement>('input[type="checkbox"]').forEach((c) => (c.checked = false));
    sortSelect.value = 'featured';
    apply();
  }

  // --- Wire up (delegate so it survives the form moving between slots) ---
  document.addEventListener('input', (e) => {
    if ((e.target as HTMLElement)?.closest('#catalog-filters')) apply();
  });
  document.addEventListener('click', (e) => {
    const t = e.target as HTMLElement;
    if (t.closest('#f-clear') || t.closest('#empty-clear')) clearAll();
  });
  sortSelect.addEventListener('change', apply);

  readURLIntoForm();
  apply();
</script>
