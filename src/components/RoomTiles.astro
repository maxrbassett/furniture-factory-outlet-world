---
import * as site from '@data/site';

const tints: Record<string, string> = {
  'Living Room': '#8a6549',
  'Bedroom': '#6f7e61',
  'Dining': '#a6722c',
  'Office': '#4a342a',
  'Outdoor': '#57644b',
};
---
<section id="rooms" class="bg-cream py-14 sm:py-20">
  <div class="mx-auto max-w-6xl px-4 sm:px-6">
    <div class="max-w-2xl">
      <p class="font-display text-sm font-600 uppercase tracking-[0.18em] text-brass-600">Start with a room</p>
      <h2 class="mt-2 font-display text-3xl font-700 text-walnut-700 sm:text-4xl">Shop by room</h2>
      <p class="mt-3 text-ink-soft">Jump straight into the catalog with a room already filtered for you.</p>
    </div>
    <div class="mt-9 grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
      {site.rooms.map((room) => (
        <a
          href={`/catalog?room=${encodeURIComponent(room.key)}`}
          class="group relative flex min-h-44 flex-col justify-end overflow-hidden rounded-2xl border border-line p-6 text-cream shadow-sm transition-transform hover:-translate-y-0.5"
          style={`background-color:${tints[room.key] ?? '#4a342a'};`}
        >
          <span aria-hidden="true" class="pointer-events-none absolute -right-6 -top-6 h-28 w-28 rounded-full bg-cream/10"></span>
          <h3 class="font-display text-2xl font-700">{room.label}</h3>
          <p class="mt-1 text-sm text-cream/85">{room.blurb}</p>
          <span class="mt-3 text-sm font-600 text-brass-300">Shop {room.label} &rarr;</span>
        </a>
      ))}
    </div>
  </div>
</section>
