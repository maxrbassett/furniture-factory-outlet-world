---
import * as site from '@data/site';
import cover from '@assets/coverphoto.jpg';
---
<section class="relative isolate overflow-hidden bg-walnut-800">
  <!-- Real storefront photo. Framed with object-position to keep the sign and
       crop the car/clutter at the bottom; color-graded + scrimmed in CSS for a
       professional cover look (the photo itself is unretouched). -->
  <img
    src={cover.src}
    width={cover.width}
    height={cover.height}
    alt={`${site.name} storefront in ${site.address.city}, ${site.address.state}`}
    fetchpriority="high"
    class="absolute inset-0 -z-10 h-full w-full object-cover [object-position:40%_32%]"
    style="filter:saturate(1.12) contrast(1.06) brightness(1.0);"
  />
  <!-- warm tint + left scrim so the copy stays legible over a bright photo -->
  <div aria-hidden="true" class="absolute inset-0 -z-10 bg-walnut-900/25"></div>
  <div aria-hidden="true" class="absolute inset-0 -z-10 bg-gradient-to-r from-walnut-900/92 via-walnut-900/60 to-walnut-900/10"></div>

  <div class="mx-auto flex min-h-[440px] max-w-6xl flex-col justify-center px-4 py-14 sm:min-h-[520px] sm:px-6">
    <div class="max-w-xl">
      <p class="font-display text-sm font-600 uppercase tracking-[0.18em] text-brass-300">{site.heroEyebrow}</p>
      <a href="/#just-in" class="mt-4 inline-flex items-center gap-2 rounded-full bg-cream/10 px-3.5 py-1.5 text-sm font-600 text-cream ring-1 ring-cream/30 backdrop-blur-sm transition-colors hover:bg-cream/20">
        <span class="relative flex h-2 w-2">
          <span class="absolute inline-flex h-full w-full animate-ping rounded-full bg-brass-400/70"></span>
          <span class="relative inline-flex h-2 w-2 rounded-full bg-brass-400"></span>
        </span>
        Just arrived this week — see what's new
      </a>
      <h1 class="mt-4 font-display text-4xl font-700 leading-[1.05] text-cream drop-shadow-sm sm:text-5xl lg:text-6xl">
        {site.heroTagline}
      </h1>
      <p class="mt-5 max-w-prose text-lg leading-relaxed text-cream/85">{site.heroSubhead}</p>
      <div class="mt-7 flex flex-wrap gap-3">
        <a href="/catalog" class="rounded-full bg-brass-500 px-6 py-3 font-700 text-walnut-900 shadow-lg shadow-brass-500/30 transition-colors hover:bg-brass-400">
          Browse the catalog
        </a>
        <a href="/#rooms" class="rounded-full border border-cream/40 px-6 py-3 font-600 text-cream transition-colors hover:bg-cream hover:text-walnut-800">
          Shop by room
        </a>
      </div>
      <p class="mt-4 text-xs text-cream/70">Outlet pricing, delivery &amp; financing details are placeholders pending confirmation.</p>
    </div>
  </div>

  <span class="absolute bottom-3 right-3 rounded-full bg-walnut-900/70 px-3 py-1.5 text-xs font-600 text-cream/90 backdrop-blur-sm">
    Our store &middot; {site.address.city}, {site.address.state}
  </span>
</section>
