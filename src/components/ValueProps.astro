---
import * as site from '@data/site';

const icons: Record<string, string> = {
  tag: 'M20.6 13.4 12 22l-9-9V4a1 1 0 0 1 1-1h9l7.6 7.6a1 1 0 0 1 0 2.8ZM7.5 7.5h.01',
  truck: 'M3 7h11v8H3zM14 10h4l3 3v2h-7zM7 19a2 2 0 1 0 0-4 2 2 0 0 0 0 4Zm10 0a2 2 0 1 0 0-4 2 2 0 0 0 0 4Z',
  card: 'M3 6h18v12H3zM3 10h18',
  leaf: 'M5 19c0-8 6-14 14-14 0 8-6 14-14 14Zm0 0c2-4 5-7 9-9',
};
---
<section id="value" class="bg-cream py-14 sm:py-20">
  <div class="mx-auto max-w-6xl px-4 sm:px-6">
    <div class="max-w-2xl">
      <p class="font-display text-sm font-600 uppercase tracking-[0.18em] text-brass-600">Why shop the outlet</p>
      <h2 class="mt-2 font-display text-3xl font-700 text-walnut-700 sm:text-4xl">Showroom quality, outlet math.</h2>
    </div>
    <ul class="mt-10 grid gap-5 sm:grid-cols-2 lg:grid-cols-4">
      {site.valueProps.map((v) => (
        <li class="rounded-2xl border border-line bg-paper p-6 shadow-sm">
          <span class="inline-flex h-11 w-11 items-center justify-center rounded-xl bg-sage-500/15 text-sage-700">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d={icons[v.icon]} />
            </svg>
          </span>
          <h3 class="mt-4 font-display text-lg font-700 text-walnut-700">{v.title}</h3>
          <p class="mt-2 text-sm leading-relaxed text-ink-soft">{v.blurb}</p>
        </li>
      ))}
    </ul>
  </div>
</section>
