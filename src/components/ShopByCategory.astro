---
/**
 * "Shop by Category" tile grid (Tyndall-style).
 *
 * Image tile per furniture type, each linking into the catalog with that
 * category pre-filtered (the catalog reads ?category=… from the URL). Uses the
 * store's real photos where one fits the category; the rest fall back to the
 * parametric SVG placeholder until more real photos come in.
 */
import type { Category } from '@data/inventory';
import ProductPlaceholder from './ProductPlaceholder.astro';

interface Tile {
  cat: Category;
  label: string;
  img?: string; // real photo (served from public/just-in/), else SVG placeholder
  color: string; // placeholder tint when no img
}

const tiles: Tile[] = [
  { cat: 'Sofas', label: 'Sofas', color: 'Oatmeal' },
  { cat: 'Sectionals', label: 'Sectionals', color: 'Slate' },
  { cat: 'Recliners', label: 'Recliners', color: 'Cognac' },
  { cat: 'Beds', label: 'Beds', img: '/just-in/ffow_post1_overstock_3.jpg', color: 'Cream' },
  { cat: 'Dressers', label: 'Dressers', img: '/just-in/ffow_post1_overstock_4.jpg', color: 'Cream' },
  { cat: 'Dining Sets', label: 'Dining', color: 'Walnut' },
  { cat: 'Tables', label: 'Tables & Ottomans', img: '/just-in/ffow_post4_ottoman_1.jpg', color: 'Oatmeal' },
  { cat: 'Mattresses', label: 'Mattresses', color: 'Cream' },
  { cat: 'Office', label: 'Home Office', img: '/just-in/ffow_post1_overstock_1.jpg', color: 'Cream' },
  { cat: 'Outdoor', label: 'Outdoor', color: 'Sage' },
];
---
<section id="categories" class="bg-cream-deep py-14 sm:py-20">
  <div class="mx-auto max-w-6xl px-4 sm:px-6">
    <div class="max-w-2xl">
      <p class="font-display text-sm font-600 uppercase tracking-[0.18em] text-brass-600">Find it faster</p>
      <h2 class="mt-2 font-display text-3xl font-700 text-walnut-700 sm:text-4xl">Shop by category</h2>
      <p class="mt-3 text-ink-soft">Browse by the kind of piece you're after — each opens the catalog filtered for you.</p>
    </div>
    <div class="mt-9 grid grid-cols-2 gap-4 sm:grid-cols-3 lg:grid-cols-5">
      {tiles.map((t) => (
        <a
          href={`/catalog?category=${encodeURIComponent(t.cat)}`}
          class="group relative block overflow-hidden rounded-2xl border border-line shadow-sm transition-transform hover:-translate-y-0.5"
        >
          <div class="aspect-square w-full overflow-hidden bg-oat">
            {t.img ? (
              <img src={t.img} alt={t.label} loading="lazy" class="h-full w-full object-cover transition-transform duration-300 group-hover:scale-[1.04]" />
            ) : (
              <ProductPlaceholder name={t.label} category={t.cat} color={t.color} ratio="1 / 1" showLabel={false} class="h-full w-full" />
            )}
          </div>
          <span aria-hidden="true" class="pointer-events-none absolute inset-0 bg-gradient-to-t from-walnut-900/80 via-walnut-900/15 to-transparent"></span>
          <span class="absolute inset-x-0 bottom-0 flex items-center justify-between gap-1 p-3">
            <span class="font-display text-base font-700 leading-tight text-cream sm:text-lg">{t.label}</span>
            <span aria-hidden="true" class="text-brass-300 transition-transform group-hover:translate-x-0.5">&rarr;</span>
          </span>
        </a>
      ))}
    </div>
  </div>
</section>
